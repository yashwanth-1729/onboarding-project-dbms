{
  "info": {
    "_postman_id": "b1a7c0de-0001-4a00-9000-onboarding0001",
    "name": "Onboarding API (DBMS Project)",
    "description": "Spring Boot REST API for the Employee Onboarding System.\n\nHOW TO USE:\n1. Run a request under 'Auth' (Login as Admin / Manager / User). Its script saves the JWT into the collection variable `token` automatically.\n2. All other requests inherit `Bearer {{token}}`, so they just work.\n3. Match the role to the route: an ADMIN token works on /admin/**, MANAGER on /manager/**, USER on /user/**.\n\nBase URL is the collection variable `baseUrl` (default http://localhost:8081 = Spring Boot directly). Change it to http://localhost:8000 to go through the FastAPI gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Saved token for', json.user && json.user.role);",
                  "}",
                  "pm.test('login ok', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@company.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login as User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                  "pm.test('login ok', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"yashwanth@company.com\",\n  \"password\": \"yashwanth123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
